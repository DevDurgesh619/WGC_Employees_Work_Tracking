# ---------- Supabase ----------
# From: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only. Used by admin scripts that need to bypass RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- Database (Prisma) ----------
# From: Supabase project → Settings → Database → Connection string (URI, with pgbouncer)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# Direct (non-pooled) connection for migrations
DIRECT_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ---------- App ----------
# Used for absolute URLs in server actions, emails, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Default IANA timezone for new users
DEFAULT_TIMEZONE=Asia/Kolkata

# ---------- Email (Resend) — Phase 8 ----------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Wallick Tracker <noreply@wallick.example>

# ---------- Observability ----------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ---------- Misc ----------
NODE_ENV=development
